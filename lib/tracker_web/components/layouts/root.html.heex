<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <link rel="icon" type="image/svg+xml" sizes="16x16" href={~p"/images/tracker-16.svg"} />
    <link rel="icon" type="image/svg+xml" sizes="32x32" href={~p"/images/tracker-32.svg"} />
    <link rel="icon" type="image/svg+xml" sizes="64x64" href={~p"/images/tracker-64.svg"} />
    <link rel="icon" type="image/x-icon" href={~p"/images/favicon.ico"} />
    <link rel="apple-touch-icon" sizes="180x180" href={~p"/images/apple-touch-icon.png"} />
    <link rel="manifest" href={~p"/manifest.webmanifest"} />
    <meta name="theme-color" content="#5b8fc9" />
    <.live_title default="Tracker" suffix=" · Tracker">
      {assigns[:page_title]}
    </.live_title>
    <link phx-track-static rel="stylesheet" href={~p"/css/app.css"} />
    <script
      :if={assigns[:interactive?]}
      defer
      phx-track-static
      type="text/javascript"
      src={~p"/assets/app.js"}
    >
    </script>
    <script :if={!assigns[:interactive?]} type="text/javascript">
      // No-JS-socket fallback: when app.js / LiveView isn't loaded, auto-submit
      // the lens form on dropdown change so the channel applies without clicking
      // "Set". Inverse-gated against app.js so it never coexists with phx-change.
      document.addEventListener("change", (e) => {
        if (e.target.matches(".lens__select")) e.target.form.requestSubmit()
      })
    </script>
  </head>
  <body>
    {@inner_content}
  </body>
</html>
